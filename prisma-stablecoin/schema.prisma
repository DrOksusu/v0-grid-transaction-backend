// 스테이블코인 아비트리지 전용 Prisma 스키마
// Separate database: grid_stablecoin_arb (Grid-bot-DB-v2 RDS 내 별도 database)
//
// Note: grid_transaction과 cross-DB relation 불가.
// userId는 grid_transaction.users.id를 참조하나 plain Int로만 저장.
// 조회가 필요하면 app 레벨에서 prisma.user.findUnique 호출.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-stablecoin"
}

datasource db {
  provider = "mysql"
  url      = env("STABLECOIN_DATABASE_URL")
}

// 스테이블코인 아비트리지 봇 설정 및 상태
// userId: grid_transaction.users.id 참조 (relation 없음)
model StablecoinArbBot {
  id     Int @id @default(autoincrement())
  userId Int @unique

  enabled    Boolean @default(false)
  killSwitch Boolean @default(false)
  live       Boolean @default(false) // M3 실거래 활성화 (false=detection only)

  coinsEnabled Json

  entryThresholdBps Int @default(20)
  tradeSizeKrw      Int @default(50000)

  perCoinMinUsd Decimal @default(10) @db.Decimal(10, 2)
  perCoinMaxUsd Decimal @default(500) @db.Decimal(10, 2)

  depegBps          Int @default(200)
  maxDailyTrades    Int @default(30)
  dailyLossLimitKrw Int @default(50000)

  totalTrades    Int       @default(0)
  totalProfitUsd Decimal   @default(0) @db.Decimal(14, 6)
  lastExecutedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades        StablecoinArbTrade[]
  opportunities StablecoinArbOpportunity[]

  @@map("stablecoin_arb_bots")
}

// 스테이블코인 아비트리지 개별 거래 기록
model StablecoinArbTrade {
  id    Int              @id @default(autoincrement())
  botId Int
  bot   StablecoinArbBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  soldCoin          String
  boughtCoin        String
  detectedAt        DateTime
  bidSoldKrw        Decimal  @db.Decimal(18, 4)
  askBoughtKrw      Decimal  @db.Decimal(18, 4)
  expectedSpreadBps Int
  plannedSizeCoin   Decimal  @db.Decimal(20, 8)

  status ArbTradeStatus

  leg1OrderUuid   String?
  leg1FilledVol   Decimal?  @db.Decimal(20, 8)
  leg1ReceivedKrw Decimal?  @db.Decimal(20, 4)
  leg1FeeKrw      Decimal?  @db.Decimal(14, 4)
  leg1CompletedAt DateTime?

  leg2OrderUuid   String?
  leg2FilledVol   Decimal?  @db.Decimal(20, 8)
  leg2SpentKrw    Decimal?  @db.Decimal(20, 4)
  leg2FeeKrw      Decimal?  @db.Decimal(14, 4)
  leg2CompletedAt DateTime?

  fallbackOrderUuid String?
  fallbackFilledVol Decimal? @db.Decimal(20, 8)
  fallbackFeeKrw    Decimal? @db.Decimal(14, 4)

  realizedSpreadBps Int?
  profitUsd         Decimal? @db.Decimal(12, 6)
  krwFlowNetKrw     Decimal? @db.Decimal(18, 4) // 보조 통계: KRW flow 기준 net (자산 변환 무시)
  totalFeeKrw       Decimal? @db.Decimal(14, 4)

  error       String?   @db.Text
  completedAt DateTime?

  @@index([botId, detectedAt])
  @@index([status])
  @@map("stablecoin_arb_trades")
}

// 스테이블코인 아비트리지 기회 로그 (실행 여부 무관)
model StablecoinArbOpportunity {
  id    BigInt           @id @default(autoincrement())
  botId Int
  bot   StablecoinArbBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  detectedAt   DateTime
  soldCoin     String
  boughtCoin   String
  bidSoldKrw   Decimal  @db.Decimal(18, 4)
  askBoughtKrw Decimal  @db.Decimal(18, 4)
  spreadBps    Int

  executed   Boolean @default(false)
  skipReason String?

  @@index([botId, detectedAt])
  @@index([soldCoin, boughtCoin, detectedAt])
  @@index([detectedAt])
  @@map("stablecoin_arb_opportunities")
}

// 아비트리지 거래 상태 열거형
enum ArbTradeStatus {
  DETECTED
  LEG1_SUBMITTED
  LEG1_FILLED
  LEG1_PARTIAL
  LEG2_SUBMITTED
  COMPLETED
  FALLBACK_DONE
  FAILED
  ABORTED
  EMERGENCY
}

// Maker-Taker 시뮬레이터 봇 설정
// 실거래 없이 DB에 가상 기록만 수행. 2~3일 관찰 후 실거래 도입 여부 판단.
model MakerTakerSimBot {
  id     Int @id @default(autoincrement())
  userId Int

  enabled    Boolean @default(true)
  killSwitch Boolean @default(false)
  live       Boolean @default(false) // 실거래 활성화 (false=시뮬레이터 유지)

  makerCoin    String
  takerCoin    String
  bidOffsetKrw Int
  quantity     Decimal @db.Decimal(20, 8)
  maxPendingMs Int     @default(3600000)

  minTakerBidKrw  Int?
  minTakerBalance Int? // 자동 일시정지 임계값. null=비활성. 잔고 < 이 값이면 enabled=false.

  makerFeeBps Int @default(5)
  takerFeeBps Int @default(5)

  // PR H — Canary Stage 3 사전 정비
  minSpreadKrw Int       @default(12)  // (bestAsk - bestBid) >= 이 값일 때만 placement
  lastResumeAt DateTime?               // enabled false→true 전환 시각 (canary T_start)

  // 크로스 거래소 지원 — 각 레그를 다른 거래소에서 실행 가능
  makerExchange String @default("upbit")  // makerCoin 거래소: "upbit" | "bithumb"
  takerExchange String @default("upbit")  // takerCoin 거래소: "upbit" | "bithumb"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades MakerTakerSimTrade[]

  @@map("maker_taker_sim_bots")
}

// Maker-Taker 시뮬레이터 개별 가상 거래 기록
// 각 row는 PENDING 주문 생성부터 FILLED/EXPIRED/CANCELLED 까지의 전체 lifecycle.
model MakerTakerSimTrade {
  id    BigInt           @id @default(autoincrement())
  botId Int
  bot   MakerTakerSimBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  makerCoin String
  takerCoin String

  makerOrderPrice  Int
  makerFilledAt    DateTime?
  makerFilledPrice Int?

  takerExecutedAt  DateTime?
  takerMarketBid   Int?
  takerSlippageBps Int?

  quantity Decimal @db.Decimal(20, 8)

  live           Boolean @default(false) // 실거래 trade 표시
  makerOrderUuid String? @db.VarChar(64) // live 주문의 Upbit uuid (status polling/cancel용)

  grossProfitKrw    Decimal? @db.Decimal(18, 4)
  feeKrw            Decimal? @db.Decimal(14, 4)
  netProfitKrw      Decimal? @db.Decimal(18, 4)
  realizedSpreadBps Int?

  // 적응형 레그 순서 (PR I)
  legOrder          String   @default("MAKER_BUY_FIRST") // MAKER_BUY_FIRST | TAKER_SELL_FIRST
  takerFirstCostKrw Decimal? @db.Decimal(18, 4)          // TAKER_SELL_FIRST: makerCoin IOC 매도로 받은 KRW
  takerFirstFeeKrw  Decimal? @db.Decimal(14, 4)          // TAKER_SELL_FIRST: IOC 매도 수수료

  status String
  notes  String? @db.Text

  @@index([botId, createdAt])
  @@index([status])
  @@map("maker_taker_sim_trades")
}

// Cross-Exchange Arbitrage Bot 설정 (2026-05-01)
// Upbit-Bithumb 양 거래소에서 동일/이종 스테이블코인 cross-exchange 차익 거래.
// buyCoin/sellCoin: null이면 coin 으로 fallback (기존 봇 하위호환).
model CrossExchangeArbBot {
  id     Int @id @default(autoincrement())
  userId Int

  enabled    Boolean @default(false)
  killSwitch Boolean @default(false)

  coin            String  // "USDE" | "USD1" | "USDS" 등 (KRW 제외). buyCoin/sellCoin null 시 fallback
  buyCoin         String? // LegA 에서 매수할 코인. null=coin 사용
  sellCoin        String? // LegB 에서 매도할 코인. null=coin 사용
  targetDirection String  // "UB" (Upbit→Bithumb 차익) | "BU" (Bithumb→Upbit 차익)
  quantity        Int     // 1회 거래 수량 (코인 단위)
  minSpreadBps    Int     @default(50)

  // 안전장치 임계값
  depegMinKrw         Int   @default(1380)
  depegMaxKrw         Int   @default(1420)
  liquidityMultiplier Float @default(1.5)
  dailyCountLimit     Int   @default(5)
  dailyLossLimitKrw   Int   @default(50000)

  // 추적
  lastResumeAt   DateTime?
  lastSkipReason String?   @db.VarChar(500) // 마지막 스킵 이유 (spread 부족, orderbook null 등)
  lastSkipAt     DateTime?                  // 마지막 스킵 시각

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades CrossExchangeArbTrade[]

  @@map("cross_exchange_arb_bots")
}

// Cross-Exchange Arbitrage 개별 거래 기록.
// LegA (legA*), LegB (legB*) 양쪽 결과 기록. status 로 성공/실패 추적.
model CrossExchangeArbTrade {
  id    BigInt              @id @default(autoincrement())
  botId Int
  bot   CrossExchangeArbBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  direction            String // "UB" | "BU"
  spreadBpsAtPlacement Int

  // Leg A (먼저 실행)
  legAExchange  String
  legASide      String
  legACoin      String? // 매수 코인 (감사 추적용. null=bot.coin)
  legAOrderId   String?
  legAFilledQty Decimal? @db.Decimal(24, 8)
  legAAvgPrice  Decimal? @db.Decimal(18, 4)
  legAFeeKrw    Decimal? @db.Decimal(18, 4)

  // Leg B (반대 거래)
  legBExchange  String
  legBSide      String
  legBCoin      String? // 매도 코인 (감사 추적용. null=bot.coin)
  legBOrderId   String?
  legBFilledQty Decimal? @db.Decimal(24, 8)
  legBAvgPrice  Decimal? @db.Decimal(18, 4)
  legBFeeKrw    Decimal? @db.Decimal(18, 4)

  profitKrw     Decimal? @db.Decimal(18, 4)
  status        String   // "FILLED" | "LEG_A_FAILED" | "LEG_B_FAILED" | "PENDING"
  failureReason String?  @db.Text

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([botId, createdAt])
  @@index([status])
  @@map("cross_exchange_arb_trades")
}

// 빗썸 단일 차익거래 글로벌 설정 (1개 row 운영)
// bithumbCoins: JSON 배열 (예: ["USDT","USDC"])
// bithumbQty: 1회 거래 수량 (코인 단위)
// bithumbMinSpreadBps: 최소 스프레드 (bps, 0.01% = 1bps)
// bithumbDailyCountLimit: 일일 최대 거래 건수
// bithumbDailyLossLimitKrw: 일일 최대 손실 한도 (KRW)
model ArbAutoConfig {
  id Int @id @default(autoincrement())

  bithumbEnabled           Boolean @default(true)
  bithumbCoins             Json    @default("[\"USDT\",\"USDC\",\"USDS\",\"USD1\",\"USDE\"]")
  bithumbQty               Int     @default(10)
  bithumbMinSpreadBps      Int     @default(10)
  bithumbDailyCountLimit   Int     @default(20)
  bithumbDailyLossLimitKrw Int     @default(50000)

  // Cross-Exchange 자동 봇 생성 기본값 (Observer가 사용)
  crossBotMinSpreadBps      Int @default(50)    // 자동 생성 봇의 실체결 최소 스프레드
  crossBotDailyCountLimit   Int @default(5)     // 자동 생성 봇의 하루 최대 거래횟수
  crossBotDailyLossLimitKrw Int @default(50000) // 자동 생성 봇의 하루 손실 한도 (KRW)

  // 향후 업비트 단일 / 크로스 auto mode 확장용 (현재 미사용)
  upbitEnabled Boolean @default(true)
  crossEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("arb_auto_config")
}

// 빗썸 단일 차익거래 개별 거래 기록
// coinSell: 매도 코인, coinBuy: 매수 코인 (같은 거래소 내)
// spreadBpsAtExec: 실행 시점 스프레드 (bps)
// status: "FILLED" | "LEG_A_FAILED" | "LEG_B_FAILED"
model BithumbSingleArbTrade {
  id BigInt @id @default(autoincrement())

  coinSell String
  coinBuy  String
  qty      Decimal @db.Decimal(20, 8)

  spreadBpsAtExec Int

  legASellOrderId String?
  legAFilledQty   Decimal? @db.Decimal(20, 8)
  legAAvgPriceKrw Decimal? @db.Decimal(18, 4)
  legAFeeKrw      Decimal? @db.Decimal(18, 4)
  legAReceivedKrw Decimal? @db.Decimal(18, 4)

  legBBuyOrderId  String?
  legBFilledQty   Decimal? @db.Decimal(20, 8)
  legBAvgPriceKrw Decimal? @db.Decimal(18, 4)
  legBFeeKrw      Decimal? @db.Decimal(18, 4)
  legBSpentKrw    Decimal? @db.Decimal(18, 4)

  profitKrw     Decimal? @db.Decimal(18, 4)
  status        String
  failureReason String?  @db.Text

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([createdAt])
  @@index([status])
  @@map("bithumb_single_arb_trades")
}
