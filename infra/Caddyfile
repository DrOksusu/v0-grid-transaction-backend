# /etc/caddy/Caddyfile — grid.koco.me
# 배포 위치: AWS Lightsail #3 (54.180.188.8), /etc/caddy/Caddyfile
# 관리자: infra/Caddyfile을 리포에서 편집 → scp로 서버 반영 → `sudo caddy validate` → `sudo systemctl reload caddy`
#
# 히스토리
# - 2026-07-06 path 기반 라우팅 도입 (/api·/socket.io → 백엔드, 그 외 → Vercel 프론트 301 리다이렉트).
# - 2026-07-07 프론트 grid.koco.me 자체호스팅 커토버 (그 외 path → 로컬 3001 컨테이너 프록시).
# - 2026-07-09 Vercel(v0-grid-transaction) 리다이렉트 전용화 + 옛 프로젝트(v0-grid-transaction-frontend) 삭제 + 예행(grid-preview) 철거.

grid.koco.me {
    # 백엔드 API (Express + Socket.IO 동일 프로세스)
    handle /api/* {
        reverse_proxy localhost:3010 {
            flush_interval -1
        }
    }

    # Socket.IO 실시간 채널 (봇 업데이트, 시세 스트림 등)
    handle /socket.io/* {
        reverse_proxy localhost:3010 {
            flush_interval -1
        }
    }

    # 프론트 자체 호스팅 (2026-07-07 이관 완료): grid-frontend-prod 컨테이너(127.0.0.1:3001) 프록시.
    #
    # ⚠️ 롤백 주의 (2026-07-09): Vercel(v0-grid-transaction.vercel.app)은 이제 grid.koco.me로 308 영구 리다이렉트한다.
    #    → 이 handle 블록을 `redir https://v0-grid-transaction.vercel.app{uri}` 로 되돌리면
    #      grid.koco.me → vercel → grid.koco.me 무한 리다이렉트 루프가 되어 프론트가 완전히 다운된다. 절대 금지.
    #    → 올바른 프론트 롤백 = 이전 grid-frontend-prod Docker 이미지를 :3001에 재기동
    #      (서버 ~/grid-frontend-src 재빌드 또는 직전 이미지 태그로 docker run).
    handle {
        reverse_proxy localhost:3001
    }
}

# 3dent.kr — DentPortal (2026-07-10 추가): auth/admin → 4300, 그 외 → 3300 (127.0.0.1 바인딩)
# ⚠️ 공유 서버(54.180.188.8) 내 별도 프로젝트(Portal_project). grid.koco.me 블록과 독립.
3dent.kr, www.3dent.kr {
    handle /auth/* {
        reverse_proxy localhost:4300
    }
    handle /admin/* {
        reverse_proxy localhost:4300
    }
    handle {
        reverse_proxy localhost:3300
    }
}

# edu.3dent.kr — DentEdu (2026-07-10 추가): /api/* → 4200, 그 외 → 3200 (127.0.0.1 바인딩)
# ⚠️ 공유 서버(54.180.188.8) 내 Edu_project. 3dent.kr(Portal)·grid.koco.me 블록과 독립.
edu.3dent.kr {
    # API 요청 → DentEdu 백엔드
    handle /api/* {
        reverse_proxy localhost:4200
    }
    # 나머지 → DentEdu 프론트엔드
    handle {
        reverse_proxy localhost:3200
    }
}
